NL2SQL_API_URL=https://potential-cod-556v6v94xv34wgr-5000.app.github.dev/nl2sql/query
NL2SQL_API_KEY=JWT_API_KEY_PLACEHOLDER

# --- Timeouts (15 minutos por defecto) ---
# HTTP client (PHP cURL) hacia la API NL2SQL (segundos)
DEMO_NL2SQL_HTTP_TIMEOUT_SECONDS=900

# Motor MySQL demo (segundos/ms)
DEMO_MYSQL_WAIT_TIMEOUT_SECONDS=900
DEMO_MYSQL_INTERACTIVE_TIMEOUT_SECONDS=900
DEMO_MYSQL_MAX_EXECUTION_TIME_MS=900000

# Healthcheck de Docker Compose (segundos)
DEMO_HEALTHCHECK_TIMEOUT_SECONDS=900

CHAT_CACHE_TTL_MINUTES=360
CHAT_MAX_MESSAGES=40
MYSQL_DEMO_USER=demo
MYSQL_DEMO_PASSWORD=demo1234
MYSQL_DEMO_DB=sakila
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
INSTALL_YII_ON_BOOT=false
