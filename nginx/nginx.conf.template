# Nginx reverse proxy for FastAPI/Gunicorn.
#
# Perfiles:
# - Local: usa HTTP en localhost (sin redirect).
# - Producción: redirige HTTP->HTTPS y termina TLS en :443.

limit_req_zone $binary_remote_addr zone=api_per_ip:10m rate=10r/s;
limit_conn_zone $binary_remote_addr zone=conn_per_ip:10m;

upstream app_backend {
    server app:5000;
    keepalive 32;
}

server {
    listen 80;
    server_name _;

    # Límite de tamaño de payload para proteger backend.
    client_max_body_size 2m;
    client_body_timeout ${NGINX_CLIENT_BODY_TIMEOUT_SECONDS}s;

    # Mantener HTTP para entorno local.
    set $redirect_to_https 1;
    if ($host ~* "^(localhost|127\\.0\\.0\\.1)$") {
        set $redirect_to_https 0;
    }
    if ($redirect_to_https = 1) {
        return 301 https://$host$request_uri;
    }

    location / {
        limit_req zone=api_per_ip burst=20 nodelay;
        limit_conn conn_per_ip 20;

        proxy_pass http://app_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Tiempo para llamadas LLM + DB.
        proxy_read_timeout ${NGINX_PROXY_READ_TIMEOUT_SECONDS}s;
        proxy_connect_timeout ${NGINX_PROXY_CONNECT_TIMEOUT_SECONDS}s;
        proxy_send_timeout ${NGINX_PROXY_SEND_TIMEOUT_SECONDS}s;

        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Frame-Options "DENY" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;
    }
}

