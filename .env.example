# --- Core auth ---
AUTH_REQUIRED=true
AUTH_JWT_SECRET=change-this-with-a-strong-32-plus-char-secret
AUTH_JWT_ALGORITHM=HS256

# --- LLM defaults ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
# Optional strict validation on startup:
LLM_STARTUP_VALIDATE=false

# Generic key (optional if you use provider-specific keys)
LLM_API_KEY=API_KEY_PLACEHOLDER

# Provider-specific API keys (set the one(s) you use)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
HUGGINGFACE_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
LLAMA_API_KEY=
COPILOT_API_KEY=

# --- Resilience knobs ---
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=0.5
LLM_HTTP_TIMEOUT_SECONDS=900
LLM_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
LLM_CIRCUIT_BREAKER_RESET_SECONDS=30

# --- Timeouts (15 minutos por defecto) ---
# FastAPI / SQL execution timeout (milisegundos)
QUERY_TIMEOUT_MS=900000

# Gunicorn (segundos)
TIMEOUT=900
GRACEFUL_TIMEOUT=900
KEEPALIVE=900

# Nginx reverse proxy (segundos)
NGINX_CLIENT_BODY_TIMEOUT_SECONDS=900
NGINX_PROXY_READ_TIMEOUT_SECONDS=900
NGINX_PROXY_CONNECT_TIMEOUT_SECONDS=900
NGINX_PROXY_SEND_TIMEOUT_SECONDS=900
NGINX_SSL_SESSION_TIMEOUT_SECONDS=900
APP_ENV=production
APP_PORT=8000
