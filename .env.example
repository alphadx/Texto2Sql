# --- Core auth ---
AUTH_REQUIRED=true
AUTH_JWT_SECRET=change-this-with-a-strong-32-plus-char-secret
AUTH_JWT_ALGORITHM=HS256

# --- LLM defaults ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1-mini
LLM_BASE_URL=https://api.openai.com/v1
# Optional strict validation on startup:
LLM_STARTUP_VALIDATE=false

# Generic key (optional if you use provider-specific keys)
LLM_API_KEY=

# Provider-specific API keys (set the one(s) you use)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
HUGGINGFACE_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
LLAMA_API_KEY=
COPILOT_API_KEY=

# --- Resilience knobs ---
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=0.5
LLM_HTTP_TIMEOUT_SECONDS=60
LLM_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
LLM_CIRCUIT_BREAKER_RESET_SECONDS=30
